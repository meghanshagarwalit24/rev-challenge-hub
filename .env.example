# Copy this file to .env and fill in your values

# MongoDB connection string (required)
MONGODB_URI=mongodb://user:password@host:port/dbname

# Port the Node.js HTTP server listens on (default: 3000)
PORT=3000

# Google OAuth 2.0 Client ID (required for "Sign in with Google")
# Create one at https://console.cloud.google.com → APIs & Services → Credentials
# Set Authorized JavaScript origins to your domain (e.g. http://localhost:3000)
VITE_GOOGLE_CLIENT_ID=
